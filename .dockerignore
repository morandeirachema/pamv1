# Keep secrets, VCS history, and local artifacts out of the build context so
# `COPY . .` cannot bake them into a build-stage layer or the build cache.
.git
.github
.env
.env.*
*.pem
*.key
*_key
recordings/
pam-server
*.log
# Docs and deploy manifests are not needed to build the binary.
docs/
deploy/
# …but the build's own Dockerfiles live under deploy/docker/, so keep them in the
# context (the `-f`/`dockerfile:` reference is read regardless; this is explicit).
!deploy/docker/Dockerfile
!deploy/docker/Dockerfile.pkcs11
README*.md
