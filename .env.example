# Vault Key Encryption Key (KEK) provider: local | vault-transit | aws-kms | pkcs11
# - local: AES key from PAM_MASTER_KEY below (DEV/TEST ONLY — key sits in env)
# - vault-transit: HashiCorp Vault Transit over HTTPS (production, vendor-aligned)
# - aws-kms: AWS KMS (production; the key never leaves KMS)
# - pkcs11: on-prem HSM via a PKCS#11 module (needs the pkcs11-tagged build /
#           Dockerfile.pkcs11 — the default static image omits it)
PAM_KEK_PROVIDER=local

# local KEK: master key (32 bytes, urlsafe base64). Generate with:
#   go run ./cmd/pam-server -genkey        (or: ./pam-server -genkey)
PAM_MASTER_KEY=

# vault-transit KEK (production): the KEK never leaves Vault
# PAM_KEK_TRANSIT_ADDR=https://vault.internal:8200
# PAM_KEK_TRANSIT_TOKEN=s.xxxxxxxx
# PAM_KEK_TRANSIT_KEY=pamv1

# aws-kms KEK (production): set PAM_KEK_PROVIDER=aws-kms; uses the AWS credential chain
# PAM_KEK_AWS_KEY_ID=arn:aws:kms:eu-west-1:123456789012:key/abcd-...
# PAM_KEK_AWS_REGION=eu-west-1

# pkcs11 KEK (on-prem HSM): set PAM_KEK_PROVIDER=pkcs11. Only works in the
# pkcs11-tagged build (go build -tags pkcs11 / Dockerfile.pkcs11). The AES
# wrapping key lives in the HSM, found by its label; the key never leaves the token.
# PAM_KEK_PKCS11_MODULE=/usr/lib/softhsm/libsofthsm2.so
# PAM_KEK_PKCS11_PIN=1234
# PAM_KEK_PKCS11_KEY_LABEL=pamv1-kek
# PAM_KEK_PKCS11_TOKEN_LABEL=pamv1        # optional; first token if empty

# Admin API key (sent as X-API-Key header / portal Sign On)
PAM_API_KEY=

# Optional break-glass: SHA-256 hex of the sealed emergency key. Generate with:
#   echo -n "the-emergency-key" | ./pam-server -hashkey
# Keep the plaintext key sealed offline; only the hash lives here.
PAM_BREAK_GLASS_KEY_HASH=

# Database: PostgreSQL (production) or "memory" (ephemeral demo)
PAM_DATABASE_URL=postgres://pam:CHANGE_ME@127.0.0.1:5432/pam?sslmode=disable

# docker-compose only: password for the bundled hardened Postgres
POSTGRES_PASSWORD=

# HTTP listen address (default :8080)
# PAM_LISTEN_ADDR=:8080

# Native HTTPS (TLS 1.2+): set both to serve TLS directly instead of behind an ingress.
# PAM_TLS_CERT=/etc/pamv1/tls.crt
# PAM_TLS_KEY=/etc/pamv1/tls.key

# Rate limit for auth endpoints (login / OIDC callback / MFA verify), attempts
# per client IP per minute; 0 disables. Default 20.
# PAM_AUTH_RATE_LIMIT=20

# Make credential reveal break-glass-only (force the recorded proxy path).
# PAM_REVEAL_DISABLED=true

# Break-glass v2: M-of-N quorum unseal. Set the threshold (M) to enable
# POST /api/breakglass/unseal; split the key into N shares offline with:
#   echo -n "<emergency-key>" | PAM_BREAK_GLASS_SHARES=5 PAM_BREAK_GLASS_THRESHOLD=3 ./pam-server -split-key
# PAM_BREAK_GLASS_THRESHOLD=3
# PAM_BREAK_GLASS_SHARES=5
# PAM_BREAK_GLASS_TTL_MIN=15          # unsealed session lifetime (minutes)

# Real-time alerts on every break-glass access/unseal and approval decision.
# Any combination of channels can be set (they fan out); air-gap mode disables all.
# PAM_ALERT_WEBHOOK=https://hooks.example.com/pamv1
# PAM_ALERT_SYSLOG=udp://syslog.internal:514        # or tcp://…
# PAM_ALERT_EMAIL_SMTP=smtp.internal:25
# PAM_ALERT_EMAIL_FROM=pamv1@example.com
# PAM_ALERT_EMAIL_TO=soc@example.com,oncall@example.com
# PAM_ALERT_EMAIL_USER=                             # optional SMTP auth
# PAM_ALERT_EMAIL_PASS=

# SSH session proxy (default :2222; set to "off" to disable)
# PAM_SSH_ADDR=:2222
# Persist the proxy host key (PEM); empty = ephemeral key regenerated each start
# PAM_SSH_HOST_KEY=/data/ssh_host_key
# Pin upstream TARGET host keys with an OpenSSH known_hosts file (recommended).
# Empty = trust any upstream key (insecure; the proxy logs a warning at startup).
# PAM_SSH_KNOWN_HOSTS=/data/known_hosts
# Where session recordings are written
# PAM_RECORDING_DIR=recordings

# Operational logging (to stdout). Level: debug|info|warn|error. Format: json|text
# PAM_LOG_LEVEL=info
# PAM_LOG_FORMAT=json

# Require a confirmed TOTP second factor for every password login. Users without
# MFA get an enrollment-only session until they set it up.
# PAM_MFA_REQUIRED=true

# OT / industrial hardening (Phase 8). See docs/OT-DEPLOYMENT.md.
# Gate every target's connect paths behind an approved access request (4-eyes /
# maintenance window). Per-target: set "require_approval":true on the target.
# PAM_REQUIRE_APPROVAL=true            # global: every target requires approval
# PAM_APPROVAL_WINDOW_MIN=60           # how long an approval stays valid
# Air-gap mode: disable ALL outbound calls (alert webhooks) for isolated sites.
# PAM_OT_AIRGAP=true
# Restrict which target protocols may be created/connected (comma-separated);
# empty = all. Use it to forbid e.g. RDP in an OT zone.
# PAM_ALLOWED_PROTOCOLS=ssh,winrm

# Credential-lifecycle worker (Phase 7). Set the interval (minutes) to enable a
# background pass that reconciles every credential (detects out-of-sync/drift)
# and rotates password credentials older than the max age. 0 = disabled.
# PAM_ROTATE_INTERVAL_MIN=60
# PAM_ROTATE_MAX_AGE_HOURS=168      # rotate secrets older than 7 days; 0 = report only
# Rotate a credential as soon as a proxied SSH session using it ends, so a secret
# used in one session can't be reused in the next:
# PAM_ROTATE_AFTER_SESSION=true
# Rotation/reconciliation connectors run over SSH (chpasswd) and WinRM (net user).
# Manual: POST /api/credentials/{id}/rotate, POST /api/credentials/{id}/reconcile
#         [?remediate=true], GET /api/reconcile (read-only drift scan).
# Credential checkout leases (POST /api/credentials/{id}/checkout|checkin): the
# secret is returned for the lease, then rotated on check-in.
# PAM_CHECKOUT_TTL_MIN=30           # checkout lease lifetime (minutes)

# Windows / WinRM command execution. HTTPS (port 5986) by default.
# PAM_WINRM_HTTPS=true
# PAM_WINRM_INSECURE_SKIP_VERIFY=false   # dev only
# PAM_WINRM_AUTH=ntlm                    # basic (default) or ntlm (AD-joined hosts)
# Interactive WinRM command loop through the SSH proxy (ssh cred@wintarget@pam).
# Each line runs as a separate WinRM command (not a stateful PowerShell).
# PAM_PROXY_WINRM=true

# RDP brokering via Apache Guacamole. Set the guacd address to enable
# GET /api/targets/{id}/rdp (a WebSocket tunnel; credentials injected into guacd).
# PAM_GUACD_ADDR=127.0.0.1:4822
# Make guacd record RDP sessions server-side (a path on the guacd host):
# PAM_GUACD_RECORDING_PATH=/recordings
# RDP security: by default guacd negotiates the mode and VERIFIES the server
# certificate. Override the mode (nla|tls|rdp) and only disable verification for
# self-signed/dev hosts:
# PAM_GUACD_RDP_SECURITY=nla
# PAM_GUACD_IGNORE_CERT=true          # dev only — skips RDP server-cert verification

# OIDC single sign-on (Authorization Code + PKCE). Set PAM_OIDC_ISSUER to enable.
# The IdP performs the login (its MFA / Conditional Access apply). For Entra:
#   issuer = https://login.microsoftonline.com/<tenant>/v2.0
# PAM_OIDC_ISSUER=
# PAM_OIDC_CLIENT_ID=
# PAM_OIDC_CLIENT_SECRET=
# PAM_OIDC_REDIRECT_URL=https://pam.example.com/api/auth/oidc/callback
# PAM_OIDC_SCOPES=openid profile
# Auth/token/JWKS endpoints are auto-discovered from the issuer; override if needed:
# PAM_OIDC_AUTH_URL=   PAM_OIDC_TOKEN_URL=   PAM_OIDC_JWKS_URL=
# Map OIDC app-role values / group ids to the four roles:
# PAM_OIDC_ROLE_ADMIN=pam.admin
# PAM_OIDC_ROLE_USER=pam.user
# PAM_OIDC_ROLE_AUDITOR=pam.auditor
# PAM_OIDC_ROLE_APPROVER=pam.approver
# Where the callback sends the browser back (portal base):
# PAM_PORTAL_URL=/

# Active Directory / LDAP login (optional). Set PAM_LDAP_URL to enable /api/login.
# Use ldaps:// (secure) — plain ldap:// only in isolated dev.
# PAM_LDAP_URL=ldaps://dc.example.com:636
# PAM_LDAP_BIND_DN=CN=svc-pam,OU=Service,DC=example,DC=com
# PAM_LDAP_BIND_PASSWORD=
# PAM_LDAP_BASE_DN=DC=example,DC=com
# PAM_LDAP_USER_FILTER=(sAMAccountName=%s)
# PAM_LDAP_INSECURE_SKIP_VERIFY=false
# Map AD group DNs to the four roles (highest privilege wins):
# PAM_LDAP_GROUP_ADMIN=CN=PAM-Admins,OU=Groups,DC=example,DC=com
# PAM_LDAP_GROUP_USER=CN=PAM-Users,OU=Groups,DC=example,DC=com
# PAM_LDAP_GROUP_AUDITOR=CN=PAM-Auditors,OU=Groups,DC=example,DC=com
# PAM_LDAP_GROUP_APPROVER=CN=PAM-Approvers,OU=Groups,DC=example,DC=com

# Microsoft Entra ID (Azure AD) login (optional). Set PAM_ENTRA_TENANT_ID to enable.
# Uses the OAuth2 resource-owner-password grant; pair with pamv1's TOTP MFA.
# PAM_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# PAM_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
# PAM_ENTRA_CLIENT_SECRET=
# PAM_ENTRA_SCOPE=                       # default "<client-id>/.default"
# PAM_ENTRA_AUTHORITY_HOST=login.microsoftonline.com   # or a sovereign cloud host
# Map Entra app-role values (or group object ids) to the four roles:
# PAM_ENTRA_ROLE_ADMIN=pam.admin
# PAM_ENTRA_ROLE_USER=pam.user
# PAM_ENTRA_ROLE_AUDITOR=pam.auditor
# PAM_ENTRA_ROLE_APPROVER=pam.approver
