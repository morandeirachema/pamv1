# Vault master key (32 bytes, urlsafe base64). Generate with:
#   go run ./cmd/pam-server -genkey        (or: ./pam-server -genkey)
PAM_MASTER_KEY=

# Admin API key (sent as X-API-Key header / portal Sign On)
PAM_API_KEY=

# Optional break-glass: SHA-256 hex of the sealed emergency key. Generate with:
#   echo -n "the-emergency-key" | ./pam-server -hashkey
# Keep the plaintext key sealed offline; only the hash lives here.
PAM_BREAK_GLASS_KEY_HASH=

# Database: PostgreSQL (production) or "memory" (ephemeral demo)
PAM_DATABASE_URL=postgres://pam:CHANGE_ME@127.0.0.1:5432/pam?sslmode=disable

# docker-compose only: password for the bundled hardened Postgres
POSTGRES_PASSWORD=

# HTTP listen address (default :8080)
# PAM_LISTEN_ADDR=:8080

# SSH session proxy (default :2222; set to "off" to disable)
# PAM_SSH_ADDR=:2222
# Persist the proxy host key (PEM); empty = ephemeral key regenerated each start
# PAM_SSH_HOST_KEY=/data/ssh_host_key
# Where session recordings are written
# PAM_RECORDING_DIR=recordings

# Operational logging (to stdout). Level: debug|info|warn|error. Format: json|text
# PAM_LOG_LEVEL=info
# PAM_LOG_FORMAT=json
